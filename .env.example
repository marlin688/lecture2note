# ── 默认平台（可选: tuzi / itssx）──
# API_PLATFORM=tuzi

# ── 平台: tuzi (兔子中转) ──
# TUZI_API_KEY=your-api-key
# TUZI_BASE_URL=https://api.tu-zi.com
# TUZI_MODEL=claude-opus-4-6

# ── 平台: itssx (CRS 中转) ──
# ITSSX_API_KEY=your-api-key
# ITSSX_BASE_URL=https://crs.itssx.com/api
# ITSSX_MODEL=claude-sonnet-4-5-20250929

# ── 直接配置（不使用平台切换时）──
ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-opus-4-6

GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_BASE_URL=https://api.tu-zi.com
# GEMINI_MODEL=gemini-3-pro-preview

# HuggingFace 镜像（国内加速）
# HF_ENDPOINT=https://hf-mirror.com
